<section class="contact section" id="contact">
  <div class="container">
    <div class="contact-inner">
      <div class="reveal">
        <span class="section-label">Contact</span>
        <h2 class="contact-title">Let's work together</h2>
        <p class="contact-description">
          Always open to new opportunities, collaborations, and interesting projects.
          Don't hesitate to reach out.
        </p>
      </div>

      <div class="contact-links reveal reveal-delay-2">
        <a href="mailto:luisillo77mario@gmail.com" class="contact-link glass-card">
          <div class="contact-link-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="M22 4L12 13 2 4"/>
            </svg>
          </div>
          <div class="contact-link-info">
            <span class="contact-link-label">Email</span>
            <span class="contact-link-value">luisillo77mario@gmail.com</span>
          </div>
          <svg class="contact-link-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </a>

