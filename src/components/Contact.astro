            <span class="contact-link-label">GitHub</span>
            <span class="contact-link-value">luisillo77D</span>
          </div>
          <svg class="contact-link-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </a>

        <a href="https://www.linkedin.com/in/luis-mario-torres-moreno-6676a21b3/" target="_blank" rel="noopener noreferrer" class="contact-link glass-card">
