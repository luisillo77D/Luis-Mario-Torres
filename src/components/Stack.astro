---
const categories = [
  {
    name: 'Frontend',
    items: [
      { name: 'Vue.js', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/vuejs/vuejs-original.svg' },
      { name: 'Astro', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/astro/astro-original.svg' },
      { name: 'React Native', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/react/react-original.svg' },
    ],
  },
  {
    name: 'Backend',
    items: [
      { name: 'Node.js', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nodejs/nodejs-original.svg' },
      { name: 'Express', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/express/express-original.svg' },
      { name: 'Rust', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/rust/rust-original.svg' },
    ],
  },
  {
    name: 'Databases',
    items: [
      { name: 'Supabase', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/supabase/supabase-original.svg' },
      { name: 'MySQL', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/mysql/mysql-original.svg' },
      { name: 'Prisma', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/prisma/prisma-original.svg' },
    ],
  },
  {
    name: 'DevOps & Tools',
    items: [
      { name: 'AWS', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/amazonwebservices/amazonwebservices-plain-wordmark.svg' },
      { name: 'Docker', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/docker/docker-original.svg' },
      { name: 'GitHub Actions', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/githubactions/githubactions-original.svg' },
      { name: 'Jenkins', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/jenkins/jenkins-original.svg' },
      { name: 'Nginx', icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nginx/nginx-original.svg' },
    ],
  },
];
---

<section class="stack section" id="stack">
  <div class="container">
    <div class="reveal">
      <span class="section-label">Technologies</span>
      <h2 class="section-title">My Stack</h2>
    </div>

    <div class="stack-categories">
      {categories.map((cat, catIdx) => (
        <div class={`stack-category reveal reveal-delay-${catIdx + 1}`}>
          <h3 class="stack-category-title">{cat.name}</h3>
          <div class="stack-items">
            {cat.items.map((item) => (
              <div class="stack-item glass-card">
                <img
                  class="stack-item-icon"
                  src={item.icon}
                  alt={item.name}
                  width="20"
                  height="20"
                  loading="lazy"
                />
                <span class="stack-item-name">{item.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stack-categories {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2xl);
  }

  .stack-category-title {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--border-subtle);
  }

  .stack-items {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .stack-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 10px 18px;
    border-radius: var(--radius-sm);
    cursor: default;
  }

  .stack-item-icon {
    width: 20px;
    height: 20px;
    object-fit: contain;
    flex-shrink: 0;
    transition: transform var(--transition-spring);
    filter: brightness(0.9);
  }

  .stack-item:hover .stack-item-icon {
    transform: scale(1.2) rotate(-5deg);
    filter: brightness(1.1);
  }

  .stack-item-name {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .stack-categories {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }
</style>
