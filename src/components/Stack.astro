---

<section class="stack section" id="stack">
  <div class="container">
    <div class="reveal">
      <span class="section-label">Tecnologias</span>
      <h2 class="section-title">Mi Stack</h2>
    </div>

    <div class="stack-categories">
      {categories.map((cat, catIdx) => (
        <div class={`stack-category reveal reveal-delay-${catIdx + 1}`}>
          <h3 class="stack-category-title">{cat.name}</h3>
          <div class="stack-items">
            {cat.items.map((item) => (
              <div class="stack-item glass-card">
                <div class="stack-item-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d={iconPaths[item.icon] || 'M12 2L2 7v10l10 6 10-6V7z'} />
                  </svg>
                </div>
                <span class="stack-item-name">{item.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stack-categories {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2xl);
  }

  .stack-category-title {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--border-subtle);
  }

  .stack-items {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .stack-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 10px 18px;
    border-radius: var(--radius-sm);
    cursor: default;
  }

  .stack-item-icon {
    color: var(--accent);
    display: flex;
    align-items: center;
    transition: transform var(--transition-spring);
  }

  .stack-item:hover .stack-item-icon {
    transform: scale(1.2) rotate(-5deg);
  }

  .stack-item-name {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .stack-categories {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }
</style>
